{
  "manifest_version": 3,
  "name": "Mock Typing",
  "version": "1.0.0",
  "description": "Simulate human-like typing to evade AI detection. Variable speed, natural errors, and realistic pauses.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "lib/key-events.js",
        "lib/human-model.js",
        "lib/typing-engine.js",
        "content/content.js"
      ],
      "run_at": "document_end"
    }
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
